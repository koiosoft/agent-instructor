#!/bin/bash
# Lanzador del orquestador agent-instructor
# Usa el directorio actual como proyecto a analizar

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Usa el python del entorno virtual si existe
if [ -f "$SCRIPT_DIR/.venv/bin/python" ]; then
    "$SCRIPT_DIR/.venv/bin/python" "$SCRIPT_DIR/instructor.py" "$@"
else
    python3 "$SCRIPT_DIR/instructor.py" "$@"
fi